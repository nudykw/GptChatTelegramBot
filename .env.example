# =============================================================================
# GptChatTelegramBot — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# The .env file is git-ignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose Profiles
# -----------------------------------------------------------------------------
# Controls which optional services are started.
# Available values (comma-separated, no spaces):
#   postgres    — start PostgreSQL container
#   mysql       — start MySQL container
#   mssql       — start Microsoft SQL Server container
#   cloudbeaver — start CloudBeaver (web DB manager) container
# Leave empty (or omit) when using SQLite — no DB container is needed.
# Examples:
#   COMPOSE_PROFILES=postgres,cloudbeaver
#   COMPOSE_PROFILES=mysql
#   COMPOSE_PROFILES=mssql,cloudbeaver
#   COMPOSE_PROFILES=
COMPOSE_PROFILES=postgres,cloudbeaver

# =============================================================================
# Bot Web Application
# =============================================================================

# Host port on which the bot web app (TelegramBotWebApp) will be available.
BOT_PORT=8080

# ASP.NET Core environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production

# Enable Swagger UI (Scalar) at /scalar/v1 and raw OpenAPI JSON at /openapi/v1.json.
# true  — always show Swagger (works in any environment, including Production)
# false — always hide Swagger
# (empty) — auto: shown in Development, hidden in Production
SWAGGER_ENABLED=false

# =============================================================================
# Telegram Bot Settings
# =============================================================================

# Bot token obtained from @BotFather.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram user ID of the bot owner (admin).
TELEGRAM_OWNER_ID=123456789

# Public base URL where your web app is reachable from the internet.
# Used to set the Telegram Webhook: {TELEGRAM_BASE_API_URL}/aibot
# If left empty, the bot runs in Polling mode instead.
# Trailing slash is optional — both formats are accepted:
#   https://example.com
#   https://example.com/
TELEGRAM_BASE_API_URL=

# =============================================================================
# Database — Active Provider
# =============================================================================

# The database provider to use.
# Supported values: Sqlite | PostgreSQL | MySQL | SqlServer
DB_PROVIDER=PostgreSQL

# Full ADO.NET connection string for the chosen provider.
# PostgreSQL example:
#   Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
# MySQL example:
#   Server=mysql;Port=3306;Database=${MYSQL_DB};User=${MYSQL_USER};Password=${MYSQL_PASSWORD}
# SQL Server example:
#   Server=mssql,1433;Database=${MSSQL_DB};User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=true
# SQLite example (no container needed):
#   Data Source=/data/bot.db
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# =============================================================================
# PostgreSQL  (profile: postgres)
# =============================================================================

# Name of the database to create / connect to.
POSTGRES_DB=gpt_chat_bot

# PostgreSQL superuser / application user name.
POSTGRES_USER=postgres

# Password for the PostgreSQL user above.
POSTGRES_PASSWORD=change_me_strong_password

# Host port mapped to the PostgreSQL container's 5432.
POSTGRES_PORT=5432

# =============================================================================
# MySQL  (profile: mysql)
# =============================================================================

# Name of the MySQL database.
MYSQL_DB=gpt_chat_bot

# Application user (non-root) for the bot.
MYSQL_USER=gpt_bot

# Password for the MySQL application user.
MYSQL_PASSWORD=change_me_strong_password

# Root password for the MySQL instance.
MYSQL_ROOT_PASSWORD=change_me_root_password

# Host port mapped to the MySQL container's 3306.
MYSQL_PORT=3306

# =============================================================================
# Microsoft SQL Server  (profile: mssql)
# =============================================================================

# Name of the SQL Server database (created on first run via migration).
MSSQL_DB=gpt_chat_bot

# SA (System Administrator) password.
# Must be at least 8 characters and contain uppercase letters, lowercase
# letters, digits and symbols (SQL Server complexity requirements).
MSSQL_SA_PASSWORD=Change_Me_Strong_Password1!

# Host port mapped to the SQL Server container's 1433.
MSSQL_PORT=1433

# =============================================================================
# CloudBeaver  (profile: cloudbeaver)
# =============================================================================

# Host port on which CloudBeaver UI will be available.
# The same value is passed to CLOUDBEAVER_WEB_SERVER_PORT inside the container.
CLOUDBEAVER_PORT=8978

# Initial admin username for CloudBeaver (set on first launch).
CLOUDBEAVER_ADMIN_NAME=cbadmin

# Initial admin password for CloudBeaver.
# Must be ≥ 8 characters.
CLOUDBEAVER_ADMIN_PASSWORD=change_me_strong_password
