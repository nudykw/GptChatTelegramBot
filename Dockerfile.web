# ── Build stage ──────────────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy project files first for NuGet restore layer caching
COPY TelegramBotWebApp/TelegramBotWebApp.csproj   TelegramBotWebApp/
COPY ServiceLayer/ServiceLayer.csproj             ServiceLayer/
COPY DataBaseLayer/DataBaseLayer.csproj           DataBaseLayer/

# Restore only the web app and its direct project dependencies
# Use --packages to ensure all transitive packages are fetched
RUN dotnet restore TelegramBotWebApp/TelegramBotWebApp.csproj \
    --packages /root/.nuget/packages

# Copy remaining source code
COPY TelegramBotWebApp/ TelegramBotWebApp/
COPY ServiceLayer/      ServiceLayer/
COPY DataBaseLayer/     DataBaseLayer/
COPY Configs/           Configs/

# Publish — restore again here to catch any missed transitive deps
RUN dotnet publish TelegramBotWebApp/TelegramBotWebApp.csproj \
    -c Release \
    -o /app/publish

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

COPY --from=build /app/publish .
# Include Configs so the web app can locate appsettings.web.json at runtime
COPY --from=build /src/Configs ./Configs

EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

ENTRYPOINT ["dotnet", "TelegramBotWebApp.dll"]
