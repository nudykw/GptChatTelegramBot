{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Error"
    },
    "Console": {
      "Enabled": true,
      "IncludeScopes": true
    },
    "File": {
      "Path": "log.txt",
      "Append": true
    }
  },
  "AppSettings": {
    "TelegramBotConfiguration": {
      "BotToken": "[YOUR_TELEGRAM_BOT_TOKEN]",
      "OwnerId": [YOUR_OWNER_ID],
      "DefaultParseMode": "Html",
      "InitialBalance": 0.1,
      "IgnoredBalanceUserIds": [ [YOUR_OWNER_ID] ],
      "AiSettings": {
        "Vision": {
          "ModelName": "gpt-4o",
          "ProviderName": "OpenAI"
        },
        "Drawing": {
          "ModelName": "dall-e-3",
          "ProviderName": "OpenAI"
        },
        "Classification": {
          "ModelName": "gpt-4o",
          "ProviderName": "OpenAI"
        },
        "ChatProviders": [
          {
            "Name": "OpenAI",
            "ProviderType": "OpenAI",
            "ApiKey": "[YOUR_OPENAI_API_KEY]",
            "ModelName": "gpt-4o-mini"
          },
          {
            "Name": "Gemini",
            "ProviderType": "Gemini",
            "ApiKey": "[YOUR_GEMINI_API_KEY]",
            "ModelName": "gemini-2.0-flash"
          },
          {
            "Name": "Grok",
            "ProviderType": "Grok",
            "ApiKey": "[YOUR_XAI_GROK_API_KEY]",
            "ModelName": "grok-3-mini",
            "BaseUrl": "https://api.x.ai"
          },
          {
            "Name": "DeepSeek",
            "ProviderType": "DeepSeek",
            "ApiKey": "[YOUR_DEEPSEEK_API_KEY]",
            "ModelName": "deepseek-chat",
            "BaseUrl": "https://api.deepseek.com"
          }
        ]
      }
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=bot.db"
    }
  }
}
