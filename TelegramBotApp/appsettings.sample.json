{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Error"
    },
    "Console": {
      "Enabled": true,
      "IncludeScopes": true
    },
    "File": {
      "Path": "log.txt",
      "Append": true
    }
  },
  "AppSettings": {
    "TelegramBotConfiguration": {
      "BotToken": "[YOUR_BOT_TOKEN_HERE]",
      "DefaultParseMode": "Html"
    },
    "GptChatConfiguration": {
      "APIKey": "[YOUR_API_KEY_HERE]"
    }
  }
  }
