{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Error"
    }
  },
  "AppSettings": {
    "TelegramBotConfiguration": {
      "BotToken": "<YOUR_TELEGRAM_BOT_TOKEN>",
      "OwnerId": 0,
      "DefaultParseMode": "Html",
      "InitialBalance": 0.1,
      "IgnoredBalanceUserIds": [],
      "BaseApiUrl": "",
      "AiSettings": {
        "Vision":         { "ModelName": "gpt-4o",    "ProviderName": "OpenAI" },
        "Drawing":        { "ModelName": "dall-e-3",  "ProviderName": "OpenAI" },
        "Classification": { "ModelName": "gpt-4o",    "ProviderName": "OpenAI" },
        "ChatProviders": [
          { "Name": "OpenAI",   "ProviderType": "OpenAI",   "ApiKey": "<YOUR_OPENAI_KEY>",   "ModelName": "gpt-4o-mini" },
          { "Name": "Gemini",   "ProviderType": "Gemini",   "ApiKey": "<YOUR_GEMINI_KEY>",   "ModelName": "gemini-2.5-flash" },
          { "Name": "Grok",     "ProviderType": "Grok",     "ApiKey": "<YOUR_GROK_KEY>",     "ModelName": "grok-3-mini", "BaseUrl": "https://api.x.ai" },
          { "Name": "DeepSeek", "ProviderType": "DeepSeek", "ApiKey": "<YOUR_DEEPSEEK_KEY>", "ModelName": "deepseek-chat", "BaseUrl": "https://api.deepseek.com" }
        ]
      },
      "ModelCacheExpiryHours": 48
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=/app/data/bot.db"
    }
  }
}
